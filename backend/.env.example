# WarTracker Backend Configuration

# Application
APP_NAME=WarTracker
APP_VERSION=1.0.0
DEBUG=True

# Database
DATABASE_URL=postgresql://wartracker:your_password_here@localhost:5432/wartracker
TEST_DATABASE_URL=postgresql://wartracker:your_password_here@localhost:5432/wartracker_test

# Redis
REDIS_URL=redis://localhost:6379

# Security (CHANGE IN PRODUCTION!)
SECRET_KEY=change-this-in-production-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Rate Limiting
RATE_LIMIT_PER_HOUR=100

# Ollama AI
OLLAMA_API_URL=http://localhost:11434
OLLAMA_MODEL_SUMMARY=qwen3.5:397b-cloud
OLLAMA_MODEL_CLASSIFICATION=glm-5:cloud

# Data Sources (Get your own API keys)
# GDELT_API_URL=https://api.gdeltproject.org/api/v2/doc/doc
# ACLED_API_KEY=your_acled_api_key
# NEWSAPI_KEY=your_newsapi_key

# CORS
CORS_ORIGINS=["http://localhost:3000","https://wartracker.org"]
